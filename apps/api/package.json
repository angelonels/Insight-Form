{
  "name": "@insightform/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "worker:dev": "tsx watch src/modules/jobs/workers.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "worker:start": "node dist/modules/jobs/workers.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:bedrock": "RUN_BEDROCK_TESTS=true vitest run src/modules/ai/bedrock-live.smoke.test.ts --passWithNoTests",
    "test:clerk": "RUN_CLERK_TESTS=true vitest run src/modules/auth/clerk-live.smoke.test.ts --passWithNoTests",
    "test:integration": "RUN_DB_TESTS=true vitest run src/test --passWithNoTests",
    "lint": "eslint src",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@insightform/shared": "workspace:*",
    "@aws-sdk/client-bedrock-runtime": "^3.826.0",
    "@clerk/backend": "^2.3.0",
    "@langchain/aws": "^1.4.0",
    "@langchain/core": "^1.2.0",
    "@langchain/langgraph": "^1.4.4",
    "bullmq": "^5.56.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "pino": "^9.7.0",
    "pino-http": "^10.4.0",
    "postgres": "^3.4.7",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.3",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.1",
    "supertest": "^7.1.1",
    "tsx": "^4.20.3",
    "vitest": "^3.2.4"
  }
}
